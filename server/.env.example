# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nutritrack?appName=Cluster0

# Telegram
BOT_TOKEN=<your_bot_token>
BOT_USERNAME=<your_bot_username>

# JWT
JWT_SECRET=<сгенерируй_длинную_случайную_строку_минимум_32_символа>
BOT_SECRET=<внутренний_секрет_для_бота_случайная_строка_32_символа>

# App
PORT=3001
NODE_ENV=development
WEBAPP_URL=https://nutritrack-topaz.vercel.app
DEFAULT_TIMEZONE=Europe/Rome

# Logging
LOG_LEVEL=info

# AI (понадобится в Спринте 3)
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# AI_PROVIDER=deepseek
# AI_FALLBACK_PROVIDER=claude
